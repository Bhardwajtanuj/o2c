# ── Backend ────────────────────────────────────────────────────────────────────
# Get a free API key at https://openrouter.ai
OPENROUTER_API_KEY=your_openrouter_api_key_here

# Path to the SQLite database (set automatically by run.sh)
DB_PATH=./data/o2c.db

# LLM model to use (free tier)
LLM_MODEL=google/gemini-flash-1.5-8b

# ── Frontend (Vite) ────────────────────────────────────────────────────────────
# Set this when deploying. For local dev, run.sh sets it automatically.
# VITE_API_URL=https://your-render-app.onrender.com
